# MuseDock Panel - Environment Configuration
# Copy this file to .env and adjust values for your server
# -------------------------------------------------------

# Panel
PANEL_NAME="MuseDock Panel"
PANEL_PORT=8444
PANEL_DEBUG=false
# Admin panel HSTS (disabled by default to avoid browser lockouts on 8444)
# Enable only if you terminate panel HTTPS on canonical 443 with trusted certs.
PANEL_HSTS_ENABLED=false

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=musedock_panel
DB_USER=musedock_panel
DB_PASS=CHANGE_ME

# Session
SESSION_LIFETIME=7200

# Caddy
CADDY_API_URL=http://localhost:2019

# PHP-FPM
FPM_PHP_VERSION=8.3
FPM_SOCKET_DIR=/run/php

# Paths
VHOSTS_DIR=/var/www/vhosts

# Security
# Comma-separated IPs allowed to access the panel (empty = allow all)
ALLOWED_IPS=
